{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "commonjs",
        "target": "es2022",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        // "moduleResolution": "node",
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["jest"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules"]
}
